<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- variant armors -->

  <ThingDef ParentName="ApparelArmorReconBase">
    <defName>Apparel_ArmorSkunk</defName>
    <label>skunk armor</label>
    <description>A variant of Recon armor with a built-in Smokepop. Skunk armor is slightly less protective than standard Recon armor.\n\nWhen activated, it releases a cloud of smoke, obscuring incoming shots and preventing turrets from locking on.\n\nSkunks provide defensive support against ranged combat units in open terrain. Imperial snipers gain a special badge of honor for dispatching skunks.</description>
    <statBases>
      <ArmorRating_Sharp>0.87</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.35</ArmorRating_Blunt>
      <ArmorRating_Heat>0.41</ArmorRating_Heat>
      <PackRadius>4.9</PackRadius>
    </statBases>
    <recipeMaker>
      <researchPrerequisites>
        <li>SmokepopBelt</li>
        <li>ReconArmor</li>
      </researchPrerequisites>
      <displayPriority>125</displayPriority>
    </recipeMaker>
    <graphicData>
      <texPath>UtilityArmors/SkunkArmor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <apparel>
      <scoreOffset>4</scoreOffset>
      <wornGraphicPath>UtilityArmors/SkunkArmor</wornGraphicPath>
    </apparel>
    <costList>
      <Plasteel>120</Plasteel>
      <ComponentIndustrial>3</ComponentIndustrial>
      <Steel>10</Steel>
      <Chemfuel>40</Chemfuel>
    </costList>
    <comps>
      <li Class="CompProperties_ApparelReloadable">
        <maxCharges>3</maxCharges>
        <ammoDef>Chemfuel</ammoDef>
        <ammoCountToRefill>10</ammoCountToRefill>
        <baseReloadTicks>60</baseReloadTicks>
        <soundReload>Standard_Reload</soundReload>
        <hotKey>Misc4</hotKey>
        <chargeNoun>smokepop</chargeNoun>
        <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
      </li>
    </comps>
    <verbs>
      <li>
        <verbClass>Verb_Smokepop</verbClass>
        <label>pop smoke</label>
        <violent>false</violent>
        <hasStandardCommand>true</hasStandardCommand>
        <targetable>false</targetable>
        <nonInterruptingSelfCast>true</nonInterruptingSelfCast>
        <onlyManualCast>True</onlyManualCast>
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="ApparelArmorPowerBase">
    <defName>Apparel_ArmorMarineDragonslayer</defName>
    <label>dragonslayer armor</label>
    <description>Firefighter equipment adapted to Marine armor frame. The armor is slightly less protective than standard Marine armor against physical damage.\n\nWhen triggered, a burst of fire-retardant foam is released, covering a wide circle around its wearer.\n\nDragonslayers form fast response units that aim to minimize civilian losses. The design was born out of necessity during the Impid rebellion. Mechanoid incursions forced the Empire to perfect it.</description>
    <statBases>
      <ArmorRating_Sharp>1.01</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.40</ArmorRating_Blunt>
      <ArmorRating_Heat>1.20</ArmorRating_Heat>
    </statBases>
    <recipeMaker>
      <researchPrerequisites>
        <li>Firefoam</li>
        <li>PoweredArmor</li>
      </researchPrerequisites>
      <displayPriority>125</displayPriority>
    </recipeMaker>
    <graphicData>
      <texPath>UtilityArmors/SkunkArmor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <tickerType>Normal</tickerType>
    <apparel>
      <scoreOffset>4</scoreOffset>
      <wornGraphicPath>UtilityArmors/SkunkArmor</wornGraphicPath>
    </apparel>
    <costList>
      <Plasteel>120</Plasteel>
      <Steel>20</Steel>
      <ComponentIndustrial>4</ComponentIndustrial>
      <Chemfuel>70</Chemfuel>
    </costList>
    <comps>
      <li Class="CompProperties_ApparelReloadable">
        <maxCharges>2</maxCharges>
        <ammoDef>Chemfuel</ammoDef>
        <ammoCountToRefill>30</ammoCountToRefill>
        <baseReloadTicks>60</baseReloadTicks>
        <soundReload>Standard_Reload</soundReload>
        <hotKey>Misc4</hotKey>
        <chargeNoun>firefoam pop</chargeNoun>
        <displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
      </li>
      <li Class="CompProperties_Explosive">
        <explosiveRadius>4.9</explosiveRadius>
        <explosiveDamageType>Extinguish</explosiveDamageType>
        <startWickHitPointsPercent>0</startWickHitPointsPercent>
        <chanceNeverExplodeFromDamage>1</chanceNeverExplodeFromDamage> <!-- Player or AI toggled. Otherwise it won't use a charge. -->
        <postExplosionSpawnThingDef>Filth_FireFoam</postExplosionSpawnThingDef>
        <postExplosionSpawnChance>1</postExplosionSpawnChance>
        <postExplosionSpawnThingCount>3</postExplosionSpawnThingCount>
        <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
        <explosionEffect>ExtinguisherExplosion</explosionEffect>
        <explosionSound>Explosion_FirefoamPopPack</explosionSound>
        <wickTicks>0</wickTicks>
        <destroyThingOnExplosionSize>9999</destroyThingOnExplosionSize><!--hack to not destroy on explosion-->
      </li>
      <li Class="CompProperties_AIUSablePack">
        <compClass>CompFirefoamPack</compClass>
        <checkInterval>60</checkInterval>
      </li>
    </comps>
    <verbs>
      <li>
        <verbClass>Verb_FirefoamPop</verbClass>
        <label>pop firefoam</label>
        <violent>false</violent>
        <hasStandardCommand>true</hasStandardCommand>
        <targetable>false</targetable>
        <nonInterruptingSelfCast>true</nonInterruptingSelfCast>
        <onlyManualCast>True</onlyManualCast>
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="ApparelArmorCataphractBase">
    <defName>Apparel_ArmorCataphractPalisade</defName>
    <label>palisade armor</label>
    <description>A variant of Cataphract armor with a shield unit. This armor is slightly less protective than standard Cataphract armor against normal damage, but it makes up for that with a shield unit.\n\nPalisades overwhelm ranks of ranged attackers with simple blunt force and resistance to projectiles.\n\nThe Palisade Pals were an infamous mercenary group, specializing in bodyguard tasks. They co-financed the development of armored suits their clients would be able to wear. But the first time it was used, the shield was configured for maximum safety, not letting even air pass through, trapping an unfortunate Archon just long enough to suffocate.</description>
    <statBases>
      <ArmorRating_Sharp>1.20</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.55</ArmorRating_Blunt>
      <ArmorRating_Heat>0.75</ArmorRating_Heat>
      <EnergyShieldRechargeRate>0.17</EnergyShieldRechargeRate>
      <EnergyShieldEnergyMax>2</EnergyShieldEnergyMax>
    </statBases>
    <tickerType>Normal</tickerType>
    <equippedStatOffsets>
      <Flammability>-0.68</Flammability>
    </equippedStatOffsets>
    <costList>
      <ComponentIndustrial>2</ComponentIndustrial>
      <Steel>50</Steel>
      <ComponentSpacer>6</ComponentSpacer>
      <Plasteel>170</Plasteel>
      <Uranium>50</Uranium>
      <BroadshieldCore>1</BroadshieldCore>
    </costList>
    <recipeMaker>
      <researchPrerequisites>
        <li>ShieldBelt</li>
        <li>CataphractArmor</li>
      </researchPrerequisites>
    </recipeMaker>
    <graphicData>
      <texPath>UtilityArmors/PalisadeArmor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <apparel>
      <scoreOffset>4</scoreOffset>
      <wornGraphicPath>UtilityArmors/PalisadeArmor</wornGraphicPath>
    </apparel>
    <comps>
      <li Class="CompProperties_Shield" />
    </comps>
    <tradeTags>
      <li>Armor</li>
    </tradeTags>
    <recipeMaker>
      <displayPriority>135</displayPriority>
    </recipeMaker>
  </ThingDef>

  <ThingDef ParentName="ApparelArmorCataphractBase" MayRequire="Ludeon.RimWorld.Royalty">
    <defName>Apparel_ArmorCataphractShelter</defName>
    <label>shelter armor</label>
    <description>A variant of Cataphract armor with a deployable low-shield projector. This armor is slightly less protective than standard Cataphract armor against normal damage, but it makes up for that with a deployable low-shield projector. Deployed, it generates a circular shield that allows bullets out but not in. The unit is designed to last only a short time before burning out.\n\nShelter armor users provide shelter for their allies.\n\nShelter usage was not favored by Imperial soldiers. They did not like hanging out in the backlines, heavily armored, being implied weaklings. But that was a misunderstanding of doctrine—Shelter should deploy a shield bubble and then charge the enemy formation, not stay cowardly inside said bubble.</description>
    <statBases>
      <ArmorRating_Sharp>1.20</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.55</ArmorRating_Blunt>
      <ArmorRating_Heat>0.75</ArmorRating_Heat>
    </statBases>
    <equippedStatOffsets>
      <Flammability>-0.68</Flammability>
    </equippedStatOffsets>
    <costList>
      <ComponentIndustrial>2</ComponentIndustrial>
      <Steel>50</Steel>
      <ComponentSpacer>6</ComponentSpacer>
      <Plasteel>170</Plasteel>
      <Uranium>50</Uranium>
      <BroadshieldCore>1</BroadshieldCore>
    </costList>
    <recipeMaker>
      <researchPrerequisites>
        <li>ShieldBelt</li>
        <li>CataphractArmor</li>
      </researchPrerequisites>
    </recipeMaker>
    <graphicData>
      <texPath>UtilityArmors/PalisadeArmor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <apparel>
      <scoreOffset>4</scoreOffset>
      <wornGraphicPath>UtilityArmors/PalisadeArmor</wornGraphicPath>
    </apparel>
    <comps>
      <li Class="CompProperties_ApparelReloadable">
        <maxCharges>1</maxCharges>
        <ammoDef>BroadshieldCore</ammoDef>
        <ammoCountToRefill>1</ammoCountToRefill>
        <baseReloadTicks>60</baseReloadTicks>
        <soundReload>Standard_Reload</soundReload>
        <hotKey>Misc4</hotKey>
        <chargeNoun>shield</chargeNoun>
        <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
      </li>
    </comps>
    <verbs>
      <li>
        <verbClass>Verb_DeployBroadshield</verbClass>
        <label>deploy low-shield</label>
        <violent>false</violent>
        <hasStandardCommand>true</hasStandardCommand>
        <targetable>false</targetable>
        <nonInterruptingSelfCast>true</nonInterruptingSelfCast>
        <onlyManualCast>True</onlyManualCast>
      </li>
    </verbs>
    <tradeTags>
      <li>Armor</li>
    </tradeTags>
    <recipeMaker>
      <displayPriority>135</displayPriority>
    </recipeMaker>
  </ThingDef>

</Defs>